---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const projects = (await getCollection("projects"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Projects — Rob Flot"
  description="Selected work including performance testing pipelines, AI systems, and backend infrastructure projects."
  path="/about"
>
  <!-- Minimal list structure keeps the page scan-friendly without introducing cards or visual components. -->
  <section>
    <h1>Projects</h1>

    <ul>
      {
        projects.map((project) => {
          const slug =
            project.data.slug ??
            project.id.split("/").pop()?.replace(/\.md$/, "");
          const tech = (project.data as { tech?: string[] }).tech;

          return (
            <li style="margin-bottom: 2rem;">
              <h2>
                <a href={`/projects/${slug}`}>
                  {project.data.title}
                </a>
              </h2>

              <p style="margin-bottom: 0.5rem;">
                {project.data.description}
              </p>

              {/* Tech stack gives a quick signal of technical depth while keeping the layout text-only. */}
              {tech && (
                <p style="color: var(--color-muted); margin-bottom: 0.5rem;">
                  Tech: {tech.join(", ")}
                </p>
              )}

              <a href={`/projects/${slug}`} style="display: inline-block; margin-top: 0.25rem;">
                Read more →
              </a>
            </li>
          );
        })
      }
    </ul>
  </section>
</BaseLayout>
