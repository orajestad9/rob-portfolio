---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const projects = (await getCollection("projects"))
    // Draft filtering keeps unfinished project pages from being generated.
    .filter((p) => !p.data.draft);

  return projects.map((project) => ({
    // Use explicit slug if provided, otherwise derive from filename safely.
    params: {
      slug:
        project.data.slug ??
        project.id.split("/").pop()?.replace(/\.md$/, ""),
    },
    props: { project },
  }));
}

const { project } = Astro.props;
// Markdown content is compiled by Astro and exposed as a renderable Content component.
const { Content } = await render(project);
---

<BaseLayout>
  <a href="/projects" style="display: inline-block; margin-bottom: 1.5rem;">
    ← Back to Projects
  </a>
  <article>
    <header style="margin-bottom: 2rem;">
      <h1>{project.data.title}</h1>
      <p style="color: var(--color-muted); margin-top: 0.5rem;">
        {project.data.description}
      </p>
    </header>

    <section>
      <Content />
    </section>
  </article>
</BaseLayout>
